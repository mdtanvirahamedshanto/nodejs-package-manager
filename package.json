{
  "name": "npm-visual-manager",
  "displayName": "NPM Visual Manager",
  "description": "Visual package manager for NPM dependencies with update checking, security audit, and bulk operations",
  "version": "1.4.0",
  "publisher": "LuisClementDev",
  "author": {
    "name": "Luis Clement Cremades"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luisssc/npm-visual-manager.git"
  },
  "bugs": {
    "url": "https://github.com/luisssc/npm-visual-manager/issues"
  },
  "homepage": "https://github.com/luisssc/npm-visual-manager#readme",
  "keywords": [
    "npm",
    "dependencies",
    "packages",
    "manager",
    "update",
    "audit",
    "security",
    "semver"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:npm-visual-manager.openManager",
    "onView:npm-visual-manager.sidebar"
  ],
  "main": "./out/core/extension.js",
  "icon": "resources/icon-marketplace.png",
  "galleryBanner": {
    "color": "#CB3837",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/visual-studio-marketplace/v/LuisClementDev.npm-visual-manager",
      "href": "https://marketplace.visualstudio.com/items?itemName=LuisClementDev.npm-visual-manager",
      "description": "VS Code Marketplace Version"
    },
    {
      "url": "https://img.shields.io/visual-studio-marketplace/d/LuisClementDev.npm-visual-manager",
      "href": "https://marketplace.visualstudio.com/items?itemName=LuisClementDev.npm-visual-manager",
      "description": "VS Code Marketplace Downloads"
    }
  ],
  "contributes": {
    "commands": [
      {
        "command": "npm-visual-manager.openManager",
        "title": "Open NPM Package Manager",
        "icon": "$(package)"
      },
      {
        "command": "npm-visual-manager.refresh",
        "title": "Refresh Dependencies",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "npm-visual-manager",
          "title": "NPM Visual Manager",
          "icon": "$(package)"
        }
      ]
    },
    "views": {
      "npm-visual-manager": [
        {
          "type": "webview",
          "id": "npm-visual-manager.sidebar",
          "name": "NPM Visual Manager",
          "contextualTitle": "NPM Visual Manager"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "npm-visual-manager.openManager"
        }
      ],
      "explorer/context": [
        {
          "command": "npm-visual-manager.openManager",
          "when": "resourceFilename == package.json",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "NPM Visual Manager",
      "properties": {
        "npm-visual-manager.columns.size": {
          "type": "boolean",
          "default": true,
          "description": "Show Size column"
        },
        "npm-visual-manager.columns.type": {
          "type": "boolean",
          "default": false,
          "description": "Show Type column"
        },
        "npm-visual-manager.columns.lastUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Show Last Update column"
        },
        "npm-visual-manager.columns.security": {
          "type": "boolean",
          "default": true,
          "description": "Show Security column"
        },
        "npm-visual-manager.columns.semverUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Show Update Type column (MAJOR/MINOR/PATCH)"
        },
        "npm-visual-manager.ignoredPackages": {
          "type": "array",
          "default": [],
          "description": "List of packages to ignore for updates",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "pinnedVersion": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build:webview",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:webview": "cd webview-ui && npm run build",
    "build:webview:dev": "cd webview-ui && npm run build:dev",
    "install:all": "npm install && cd webview-ui && npm install",
    "dev": "npm run build:webview:dev && npm run compile",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"types/**/*.d.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"types/**/*.d.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
