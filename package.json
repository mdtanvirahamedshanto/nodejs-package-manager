{
  "name": "nodejs-package-manager",
  "displayName": "Node.js Package Manager",
  "description": "A Visual Studio Code extension for managing Node.js dependencies with updates, security audits, and bulk operations.",
  "version": "1.5.4",
  "publisher": "mdtanvirahamedshanto",
  "author": {
    "name": "Md Tanvir Ahamed Shanto",
    "email": "mdtanvirahamedshanto@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mdtanvirahamedshanto/nodejs-package-manager.git"
  },
  "bugs": {
    "url": "https://github.com/mdtanvirahamedshanto/nodejs-package-manager/issues"
  },
  "homepage": "https://github.com/mdtanvirahamedshanto/nodejs-package-manager#readme",
  "keywords": [
    "npm",
    "dependencies",
    "packages",
    "manager",
    "update",
    "audit",
    "security",
    "semver"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:nodejs-package-manager.openManager",
    "onView:nodejs-package-manager.sidebar"
  ],
  "main": "./out/core/extension.js",
  "icon": "resources/nodejs-package-manager.png",
  "galleryBanner": {
    "color": "#CB3837",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/visual-studio-marketplace/v/mdtanvirahamedshanto.nodejs-package-manager",
      "href": "https://marketplace.visualstudio.com/items?itemName=mdtanvirahamedshanto.nodejs-package-manager",
      "description": "VS Code Marketplace Version"
    },
    {
      "url": "https://img.shields.io/visual-studio-marketplace/d/mdtanvirahamedshanto.nodejs-package-manager",
      "href": "https://marketplace.visualstudio.com/items?itemName=mdtanvirahamedshanto.nodejs-package-manager",
      "description": "VS Code Marketplace Downloads"
    }
  ],
  "contributes": {
    "commands": [
      {
        "command": "nodejs-package-manager.openManager",
        "title": "Open Node.js Package Manager",
        "icon": "$(package)"
      },
      {
        "command": "nodejs-package-manager.showSidebar",
        "title": "Show Node.js Package Manager Sidebar",
        "icon": "$(list-tree)"
      },
      {
        "command": "nodejs-package-manager.refresh",
        "title": "Refresh Dependencies",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nodejs-package-manager",
          "title": "Package Manager",
          "icon": "resources/sidebar.svg"
        }
      ]
    },
    "views": {
      "nodejs-package-manager": [
        {
          "type": "webview",
          "id": "nodejs-package-manager.sidebar",
          "name": "Package Manager",
          "contextualTitle": "Package Manager"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "nodejs-package-manager.openManager"
        },
        {
          "command": "nodejs-package-manager.showSidebar"
        }
      ],
      "explorer/context": [
        {
          "command": "nodejs-package-manager.openManager",
          "when": "resourceFilename == package.json",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Package Manager",
      "properties": {
        "nodejs-package-manager.columns.size": {
          "type": "boolean",
          "default": true,
          "description": "Show Size column"
        },
        "nodejs-package-manager.columns.type": {
          "type": "boolean",
          "default": false,
          "description": "Show Type column"
        },
        "nodejs-package-manager.columns.lastUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Show Last Update column"
        },
        "nodejs-package-manager.columns.security": {
          "type": "boolean",
          "default": true,
          "description": "Show Security column"
        },
        "nodejs-package-manager.columns.semverUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Show Update Type column (MAJOR/MINOR/PATCH)"
        },
        "nodejs-package-manager.ignoredPackages": {
          "type": "array",
          "default": [],
          "description": "List of packages to ignore for updates",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "pinnedVersion": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build:webview",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:webview": "cd webview-ui && npm run build",
    "build:webview:dev": "cd webview-ui && npm run build:dev",
    "package:vsix": "npx -y @vscode/vsce@2.24.0 package",
    "publish:ovsx": "npm run package:vsix && npx -y ovsx publish nodejs-package-manager-$(node -p \"require('./package.json').version\").vsix -p \"$OVSX_TOKEN\"",
    "install:all": "npm install && cd webview-ui && npm install",
    "dev": "npm run build:webview:dev && npm run compile",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"types/**/*.d.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"types/**/*.d.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
